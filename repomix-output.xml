  <div class="setup-right">
    <div class="ph"><div class="ph-dot" style="background:var(--quasar);box-shadow:0 0 8px var(--quasar)"></div><h2>Live Graph Preview</h2></div>
    <div class="preview-wrap">
      <canvas id="preview-canvas"></canvas>
      <div id="preview-msg"><h3>EMPTY UNIVERSE</h3><p>Add stars and wormholes to build your career graph</p></div>
    </div>
