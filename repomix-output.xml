  <div class="fg"><label class="lbl">Risk <span id="ee-risk-v" style="color:var(--pulsar)">0.30</span></label><input class="rng" id="ee-risk" type="range" min="0" max="1" step="0.05" value="0.3"/></div>
  <div class="modal-acts">
    <button class="btn btn-c" onclick="closeModal('modal-edge')">Cancel</button>
    <button class="btn btn-g btn-full" onclick="confirmAddEdge()">Create Wormhole</button>
  </div>
</div>
</div>

<div id="app">
<div id="topbar">
  <div class="brand">
    <div class="brand-orb"></div>
    <div><div class="brand-name">PATHFORGE</div><div class="brand-sub">Career Universe · AI Powered</div></div>
  </div>
  <div class="nav-tabs">
