      <div class="fg"><label class="lbl">Max Years <span class="rng-v" id="my-v">12</span></label><input class="rng" id="my" type="range" min="2" max="20" step="1" value="12"/></div>
      <div class="fg"><label class="lbl">Max Risk <span class="rng-v" id="mr-v">0.60</span></label><input class="rng" id="mr" type="range" min="0.1" max="1" step="0.05" value="0.6"/></div>
      <div class="fg"><label class="lbl">Analysis Criterion</label><input class="inp" id="criterion" value="best overall growth with manageable risk"/></div>
    </div>
    <div style="padding:12px;flex-shrink:0;border-top:1px solid var(--border)">
      <button class="btn btn-launch" id="launch-btn" onclick="launchExploration()">🚀  Explore All Futures</button>
