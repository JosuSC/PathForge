      <div class="bt-path" id="bt-path"></div>
      <div class="bt-metrics" id="bt-mets"></div>
    </div>
  </div>
  <div class="llm-panel">
    <div class="llm-hdr">
      <span class="llm-title">🤖 Gemini AI Analysis</span>
      <button class="btn btn-c btn-sm" id="analyze-btn" onclick="requestAnalysis()">Analyze All</button>
    </div>
    <div class="crit-row"><input class="inp" id="crit-disp" value="best overall growth with manageable risk"/></div>
