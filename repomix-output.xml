// E. API
const API={
  async loadDefault(){try{const r=await fetch(`${S.API}/api/graph`);if(!r.ok)throw 0;return r.json();}catch{return null;}},
  async analyze(trajs,crit,prof){const r=await fetch(`${S.API}/api/analyze`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({trajectories:trajs,criterion:crit,user_profile:prof})});return r.json();},
  exploreWS(req,onStep,onResult,onDone,onErr){
    try{
      const ws=new WebSocket(S.API.replace('http','ws')+'/ws/explore');
      ws.onopen=()=>ws.send(JSON.stringify({type:'start',data:req}));
      ws.onmessage=e=>{const m=JSON.parse(e.data);if(m.type==='step')onStep(m);if(m.type==='result')onResult(m);if(m.type==='done')onDone();if(m.type==='error')onErr(m.msg);};
      ws.onerror=()=>onErr('WS failed');
    }catch(e){onErr(e.message);}
  },
