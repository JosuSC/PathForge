<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
/* ═══════════════════════════════════════════════════════
   PATHFORGE — Main Application
   A. State
   B. SpaceBG  — animated 2D space background
   C. Preview  — 2D setup preview
   D. U3D      — Three.js 3D universe
   E. API      — backend calls
   F. Demo     — offline simulation
   G. UI       — helpers
   H. Logic    — exploration + analysis
   I. Init
═══════════════════════════════════════════════════════ */

// A. STATE
const S={nodes:[],edges:[],trajectories:[],exploring:false,autoRot:true,showLbls:true,showAllTraj:false,currentView:'setup',API:'http://localhost:8000'};
const PAL=[0x00c8ff,0xb44dff,0xffc843,0xff6b35,0x00ff8c,0xff3355,0x4fc3f7,0xce93d8,0xffcc02,0x69f0ae,0xf48fb1,0x80deea,0xff9800,0x00bcd4,0x9c27b0,0x4caf50];
const pc=i=>'#'+PAL[i%PAL.length].toString(16).padStart(6,'0');

// B. SPACE BACKGROUND — deep space with constellations, planets, shooting stars
const SpaceBG=(()=>{
  let cv,cx,W,H,stars=[],nebulae=[],planets=[],shoots=[],consts=[],t=0;
  function init(){
    cv=document.getElementById('space-canvas');cx=cv.getContext('2d');
    resize();window.addEventListener('resize',()=>{resize();build();});build();render();
  }
  function resize(){W=cv.width=window.innerWidth;H=cv.height=window.innerHeight;}
  function build(){
    stars=[];
    for(let i=0;i<800;i++) stars.push({x:Math.random()*W,y:Math.random()*H,r:.2+Math.random()*1.4,a:.3+Math.random()*.7,da:(Math.random()-.5)*.007,tw:Math.random()*Math.PI*2,col:['#a0cfff','#ffe8b0','#c0a0ff','#ffffff','#80ffcc'][Math.floor(Math.random()*5)]});
    nebulae=[];
    const nc=[['#0a1a3a','#1a0a2a'],['#0a2a1a','#1a2a0a'],['#2a0a1a','#1a1a2a'],['#0a1a2a','#2a0a2a'],['#1a0a3a','#0a1a1a']];
    for(let i=0;i<7;i++) nebulae.push({x:Math.random()*W,y:Math.random()*H,rx:100+Math.random()*220,ry:70+Math.random()*160,rot:Math.random()*Math.PI,c1:nc[i%nc.length][0],c2:nc[i%nc.length][1],op:.1+Math.random()*.14});
    consts=[
      {pts:[[.08,.18],[.14,.13],[.21,.17],[.27,.12],[.34,.19]]},
      {pts:[[.58,.08],[.64,.14],[.71,.09],[.69,.19],[.64,.24]]},
      {pts:[[.84,.38],[.90,.33],[.92,.41],[.88,.47],[.82,.44]]},
      {pts:[[.38,.68],[.44,.63],[.50,.71],[.48,.79],[.41,.77]]},
      {pts:[[.18,.83],[.24,.78],[.31,.81],[.29,.89]]},
      {pts:[[.55,.35],[.60,.28],[.66,.33],[.64,.42],[.58,.45]]},
    ].map(c=>({pts:c.pts.map(p=>({x:p[0]*W,y:p[1]*H}))}));
    planets=[
      {x:W*.76,y:H*.19,r:17,h:220,ring:true,sp:.0003},
      {x:W*.14,y:H*.72,r:10,h:40,ring:false,sp:.0005},
      {x:W*.89,y:H*.76,r:7,h:160,ring:false,sp:.0008},
      {x:W*.44,y:H*.87,r:13,h:300,ring:true,sp:.0002},
    ];
    shoots=[];
  }
  function render(){
    requestAnimationFrame(render);t+=.007;
    const g=cx.createRadialGradient(W*.5,H*.5,0,W*.5,H*.5,Math.max(W,H)*.72);
    g.addColorStop(0,'#030b1a');g.addColorStop(.5,'#02060f');g.addColorStop(1,'#00000a');
    cx.fillStyle=g;cx.fillRect(0,0,W,H);
    nebulae.forEach(n=>{
      cx.save();cx.translate(n.x,n.y);cx.rotate(n.rot+t*.008);
      const ng=cx.createRadialGradient(0,0,0,0,0,n.rx);
      ng.addColorStop(0,n.c1);ng.addColorStop(1,'transparent');
      cx.globalAlpha=n.op*(.8+.2*Math.sin(t*.3));cx.scale(1,n.ry/n.rx);
      cx.beginPath();cx.arc(0,0,n.rx,0,Math.PI*2);cx.fillStyle=ng;cx.fill();cx.restore();
    });
    cx.save();cx.strokeStyle='rgba(140,170,255,0.14)';cx.lineWidth=.7;cx.setLineDash([3,6]);
    consts.forEach(c=>{cx.beginPath();c.pts.forEach((p,i)=>i===0?cx.moveTo(p.x,p.y):cx.lineTo(p.x,p.y));cx.stroke();});
    cx.setLineDash([]);
    consts.forEach(c=>c.pts.forEach(p=>{cx.beginPath();cx.arc(p.x,p.y,1.5,0,Math.PI*2);cx.fillStyle='rgba(180,210,255,0.6)';cx.fill();}));
    cx.restore();
    stars.forEach(s=>{
      s.tw+=s.da;const a=s.a*(.5+.5*Math.sin(s.tw));
      cx.save();cx.globalAlpha=a;cx.fillStyle=s.col;cx.beginPath();cx.arc(s.x,s.y,s.r,0,Math.PI*2);cx.fill();
      if(s.r>1.1){cx.globalAlpha=a*.35;cx.strokeStyle=s.col;cx.lineWidth=.5;const fl=s.r*3;cx.beginPath();cx.moveTo(s.x-fl,s.y);cx.lineTo(s.x+fl,s.y);cx.moveTo(s.x,s.y-fl);cx.lineTo(s.x,s.y+fl);cx.stroke();}
      cx.restore();
    });
    planets.forEach(p=>{
      const px=p.x+Math.sin(t*p.sp*100)*12,py=p.y+Math.cos(t*p.sp*80)*7;
      cx.save();
      const gl=cx.createRadialGradient(px,py,0,px,py,p.r*3);
      gl.addColorStop(0,`hsla(${p.h},80%,60%,.18)`);gl.addColorStop(1,'transparent');
      cx.fillStyle=gl;cx.beginPath();cx.arc(px,py,p.r*3,0,Math.PI*2);cx.fill();
      const bo=cx.createRadialGradient(px-p.r*.3,py-p.r*.3,p.r*.1,px,py,p.r);
      bo.addColorStop(0,`hsl(${p.h+30},70%,72%)`);bo.addColorStop(.5,`hsl(${p.h},60%,42%)`);bo.addColorStop(1,`hsl(${p.h-20},70%,18%)`);
      cx.fillStyle=bo;cx.beginPath();cx.arc(px,py,p.r,0,Math.PI*2);cx.fill();
      cx.globalAlpha=.28;cx.strokeStyle=`hsl(${p.h+40},80%,70%)`;cx.lineWidth=1.5;cx.beginPath();cx.arc(px,py,p.r+2,0,Math.PI*2);cx.stroke();
      if(p.ring){cx.globalAlpha=.33;cx.strokeStyle=`hsl(${p.h},60%,65%)`;cx.lineWidth=2;cx.save();cx.translate(px,py);cx.scale(1,.28);cx.beginPath();cx.arc(0,0,p.r*2.2,0,Math.PI*2);cx.stroke();cx.restore();}
      cx.restore();
    });
    if(shoots.length<3&&Math.random()<.004) shoots.push({x:Math.random()*W,y:Math.random()*(H*.4),vx:4+Math.random()*6,vy:2+Math.random()*3,len:65+Math.random()*80,life:1});
    shoots=shoots.filter(ss=>{
      ss.x+=ss.vx;ss.y+=ss.vy;ss.life-=.024;if(ss.life<=0)return false;
      const mag=Math.hypot(ss.vx,ss.vy);cx.save();cx.globalAlpha=ss.life*.85;
      const sg=cx.createLinearGradient(ss.x,ss.y,ss.x-ss.vx*ss.len/mag,ss.y-ss.vy*ss.len/mag);
      sg.addColorStop(0,'#ffffff');sg.addColorStop(1,'transparent');
      cx.strokeStyle=sg;cx.lineWidth=1.5;cx.beginPath();cx.moveTo(ss.x,ss.y);cx.lineTo(ss.x-ss.vx*ss.len/mag,ss.y-ss.vy*ss.len/mag);cx.stroke();cx.restore();
      return true;
    });
  }
  return{init};
})();

// C. PREVIEW CANVAS
const Preview=(()=>{
  let cv,cx,W,H,hov=null;const pos={};
  function init(){cv=document.getElementById('preview-canvas');cx=cv.getContext('2d');resize();cv.addEventListener('mousemove',onHov);window.addEventListener('resize',()=>{resize();draw();});}
  function resize(){const w=cv.parentElement;W=cv.width=w.clientWidth||600;H=cv.height=w.clientHeight||400;}
  function layout(){
    const n=S.nodes.length;if(!n)return;const cx2=W/2,cy2=H/2,r=Math.min(W,H)*.34;
    S.nodes.forEach((nd,i)=>{const a=(i/n)*Math.PI*2-Math.PI/2,jt=Math.sin(i*7.3+2)*18;pos[nd.id]={x:cx2+Math.cos(a)*(r+jt),y:cy2+Math.sin(a)*(r+jt*.5),col:pc(i),i};});
  }
  function draw(){
    if(!cx)return;cx.clearRect(0,0,W,H);
    if(!S.nodes.length){document.getElementById('preview-msg').style.display='flex';return;}
    document.getElementById('preview-msg').style.display='none';layout();
    S.edges.forEach(e=>{
      const a=pos[e.from_node],b=pos[e.to_node];if(!a||!b)return;
      const mx=(a.x+b.x)/2+(b.y-a.y)*.15,my=(a.y+b.y)/2-(b.x-a.x)*.15;
      cx.save();cx.globalAlpha=.35;cx.strokeStyle='rgba(0,200,255,0.55)';cx.lineWidth=1.2;cx.setLineDash([4,6]);
      cx.beginPath();cx.moveTo(a.x,a.y);cx.quadraticCurveTo(mx,my,b.x,b.y);cx.stroke();
      const dx=b.x-mx,dy=b.y-my,ang=Math.atan2(dy,dx);
      cx.globalAlpha=.5;cx.setLineDash([]);cx.fillStyle='rgba(0,200,255,0.6)';
      cx.beginPath();cx.moveTo(b.x,b.y);cx.lineTo(b.x-8*Math.cos(ang-.4),b.y-8*Math.sin(ang-.4));cx.lineTo(b.x-8*Math.cos(ang+.4),b.y-8*Math.sin(ang+.4));cx.closePath();cx.fill();cx.restore();
    });
    S.nodes.forEach(nd=>{
      const p=pos[nd.id];if(!p)return;
      const isH=hov===nd.id,isS=document.getElementById('src-sel').value===nd.id;
      const r=isH?13:isS?12:9;
      cx.save();cx.globalAlpha=isH?.45:.2;cx.fillStyle=p.col;cx.beginPath();cx.arc(p.x,p.y,r*2.5,0,Math.PI*2);cx.fill();
      cx.globalAlpha=1;cx.fillStyle=p.col;cx.shadowColor=p.col;cx.shadowBlur=isH?22:10;cx.beginPath();cx.arc(p.x,p.y,r,0,Math.PI*2);cx.fill();
      if(isS){cx.strokeStyle='#fff';cx.lineWidth=2;cx.shadowBlur=0;cx.beginPath();cx.arc(p.x,p.y,r+4,0,Math.PI*2);cx.stroke();}
      cx.restore();
      cx.save();cx.font=`${isH?'500 ':''}12px 'Rajdhani',sans-serif`;cx.fillStyle=isH?'#fff':'rgba(221,238,255,.7)';cx.textAlign='center';cx.fillText(nd.label,p.x,p.y+r+13);cx.restore();
    });
  }
  function onHov(e){const rc=cv.getBoundingClientRect(),mx=e.clientX-rc.left,my=e.clientY-rc.top;hov=null;for(const nd of S.nodes){const p=pos[nd.id];if(p&&Math.hypot(mx-p.x,my-p.y)<15){hov=nd.id;break;}}cv.style.cursor=hov?'pointer':'default';draw();}
  return{init,draw};
})();

// D. THREE.JS UNIVERSE
const U3D=(()=>{
  let scene,camera,renderer;let rc,mouse;
  const NM={},EL=[],TL=[],BL=[],LS=[];
  let phi=Math.PI/2.5,theta=0,radius=30;
  let isDrag=false,pmx=0,pmy=0;
  let autoRot=true,showLbls=true,t3=0;

  function init(){
    const cv=document.getElementById('three-canvas');if(!cv)return;
    scene=new THREE.Scene();scene.fog=new THREE.FogExp2(0x00000a,.007);
    camera=new THREE.PerspectiveCamera(55,cv.clientWidth/cv.clientHeight,.1,800);
    updCam();
    renderer=new THREE.WebGLRenderer({canvas:cv,antialias:true,alpha:false});
    renderer.setSize(cv.clientWidth,cv.clientHeight);renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
    renderer.toneMapping=THREE.ACESFilmicToneMapping;renderer.toneMappingExposure=1.1;
    rc=new THREE.Raycaster();mouse=new THREE.Vector2();
    scene.add(new THREE.AmbientLight(0x0a1628,3));
    const pl=new THREE.PointLight(0x00c8ff,4,100);pl.position.set(0,0,25);scene.add(pl);
    const pl2=new THREE.PointLight(0xb44dff,2,80);pl2.position.set(-20,10,-10);scene.add(pl2);
    _particles();_nebula();
    cv.addEventListener('mousedown',e=>{isDrag=true;pmx=e.clientX;pmy=e.clientY;});
    window.addEventListener('mouseup',()=>isDrag=false);
    cv.addEventListener('mousemove',onMM);cv.addEventListener('click',onMC);
    cv.addEventListener('wheel',e=>{radius=Math.max(8,Math.min(70,radius+e.deltaY*.04));});
    window.addEventListener('resize',()=>{if(!renderer)return;renderer.setSize(cv.clientWidth,cv.clientHeight);camera.aspect=cv.clientWidth/cv.clientHeight;camera.updateProjectionMatrix();});
    anim();
  }
  function _particles(){
    const n=4000,geo=new THREE.BufferGeometry(),p=new Float32Array(n*3),c=new Float32Array(n*3);
    for(let i=0;i<n;i++){p[i*3]=(Math.random()-.5)*600;p[i*3+1]=(Math.random()-.5)*600;p[i*3+2]=(Math.random()-.5)*600;const t=Math.random();if(t<.55){c[i*3]=.55;c[i*3+1]=.75;c[i*3+2]=1;}else if(t<.8){c[i*3]=1;c[i*3+1]=.9;c[i*3+2]=.5;}else{c[i*3]=.7;c[i*3+1]=.4;c[i*3+2]=1;}}
    geo.setAttribute('position',new THREE.BufferAttribute(p,3));geo.setAttribute('color',new THREE.BufferAttribute(c,3));
    scene.add(new THREE.Points(geo,new THREE.PointsMaterial({size:.15,vertexColors:true,transparent:true,opacity:.75,sizeAttenuation:true})));
  }
  function _nebula(){
    [[0x0a1628,.06],[0x1a0a3a,.05],[0x0a2a1a,.04]].forEach(([cl,op])=>{
      const m=new THREE.Mesh(new THREE.PlaneGeometry(200,140),new THREE.MeshBasicMaterial({color:cl,transparent:true,opacity:op,side:THREE.DoubleSide}));
      m.position.set((Math.random()-.5)*50,(Math.random()-.5)*30,-60-Math.random()*40);m.rotation.z=Math.random()*Math.PI;scene.add(m);
    });
  }
  function updCam(){camera.position.set(radius*Math.sin(phi)*Math.sin(theta),radius*Math.cos(phi),radius*Math.sin(phi)*Math.cos(theta));camera.lookAt(0,0,0);}
  function npos(nd,i,tot){
    const g=Math.PI*(3-Math.sqrt(5)),y=1-(i/Math.max(tot-1,1))*2,r2=Math.sqrt(1-y*y),a=g*i,sp=10+(nd.avg_salary/18000);
    return new THREE.Vector3(Math.cos(a)*r2*sp,y*sp,Math.sin(a)*r2*sp);
  }
  function addNode(nd,i){
    const tot=S.nodes.length,p=npos(nd,i,tot),cl=PAL[i%PAL.length],sz=.27+(nd.avg_salary/200000)*.5;
    const m=new THREE.Mesh(new THREE.SphereGeometry(sz,20,20),new THREE.MeshStandardMaterial({color:cl,emissive:cl,emissiveIntensity:.55,metalness:.1,roughness:.15}));
    m.position.copy(p);m.userData={nodeId:nd.id,baseScale:1,phase:i*.8,color:cl};scene.add(m);NM[nd.id]=m;
    const gw=new THREE.Mesh(new THREE.SphereGeometry(sz*3,16,16),new THREE.MeshBasicMaterial({color:cl,transparent:true,opacity:.11,side:THREE.BackSide}));
    m.add(gw);m.userData.glow=gw;
    const sm=new THREE.LineBasicMaterial({color:cl,transparent:true,opacity:.5});
    [[1,0,0],[0,1,0],[0,0,1]].forEach(ax=>{m.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-ax[0]*sz*4,-ax[1]*sz*4,-ax[2]*sz*4),new THREE.Vector3(ax[0]*sz*4,ax[1]*sz*4,ax[2]*sz*4)]),sm));});
    if(showLbls)addLabel(nd,m,cl);
  }
  function addLabel(nd,mesh,cl){
    const cv2=document.createElement('canvas');cv2.width=256;cv2.height=60;
    const c=cv2.getContext('2d');c.clearRect(0,0,256,60);c.font='bold 20px Rajdhani,sans-serif';
    c.fillStyle='rgba(0,0,0,.5)';c.fillRect(0,18,256,28);
    c.fillStyle='#'+cl.toString(16).padStart(6,'0');c.textAlign='center';c.fillText(nd.label,128,38);
    const sp=new THREE.Sprite(new THREE.SpriteMaterial({map:new THREE.CanvasTexture(cv2),transparent:true}));
    const s=mesh.geometry.parameters.radius;sp.scale.set(3.8,.95,1);sp.position.set(0,s+.75,0);
    mesh.add(sp);mesh.userData.lbl=sp;LS.push(sp);
  }
  function rebuildAll(){
    Object.keys(NM).forEach(id=>{scene.remove(NM[id]);delete NM[id];});EL.forEach(l=>scene.remove(l));EL.length=0;LS.length=0;
    S.nodes.forEach((n,i)=>addNode(n,i));buildEdges();
  }
  function buildEdges(){
    EL.forEach(l=>scene.remove(l));EL.length=0;
    S.edges.forEach(e=>{
      const a=NM[e.from_node],b=NM[e.to_node];if(!a||!b)return;
      const l=new THREE.Line(new THREE.BufferGeometry().setFromPoints(curv(a.position,b.position,14)),new THREE.LineBasicMaterial({color:0x0a2040,transparent:true,opacity:.22+(.6-e.risk)*.3}));
      scene.add(l);EL.push(l);
    });
  }
  function curv(a,b,n){const m=new THREE.Vector3().addVectors(a,b).multiplyScalar(.5);m.x+=(Math.random()-.5)*3;m.y+=(Math.random()-.5)*3;return new THREE.QuadraticBezierCurve3(a,m,b).getPoints(n);}
  function clearTL(){TL.forEach(l=>scene.remove(l));TL.length=0;Object.values(NM).forEach(m=>{m.userData.selected=false;m.userData.baseScale=1;m.material.emissiveIntensity=.55;});}
  function clearBL(){BL.forEach(l=>scene.remove(l));BL.length=0;}
  function hlTraj(nodes,cl=0xffd700){
    clearTL();
    for(let i=0;i<nodes.length-1;i++){const a=NM[nodes[i]],b=NM[nodes[i+1]];if(!a||!b)continue;const l=new THREE.Line(new THREE.BufferGeometry().setFromPoints(curv(a.position,b.position,22)),new THREE.LineBasicMaterial({color:cl,transparent:true,opacity:.95}));scene.add(l);TL.push(l);}
    nodes.forEach(id=>{const m=NM[id];if(m){m.userData.selected=true;m.userData.baseScale=1.5;m.material.emissiveIntensity=1.2;}});
  }
  function animBeam(beam,completed){
    clearBL();
    beam.forEach(path=>{for(let i=0;i<path.length-1;i++){const a=NM[path[i]],b=NM[path[i+1]];if(!a||!b)continue;const l=new THREE.Line(new THREE.BufferGeometry().setFromPoints(curv(a.position,b.position,9)),new THREE.LineBasicMaterial({color:0xb44dff,transparent:true,opacity:.78}));scene.add(l);BL.push(l);}});
    completed.slice(-3).forEach(path=>path.forEach(id=>{const m=NM[id];if(m){const b=m.userData.baseScale||1;m.userData.baseScale=1.8;setTimeout(()=>m.userData.baseScale=b,320);}}));
  }
  function anim(){requestAnimationFrame(anim);t3+=.005;if(autoRot)theta+=.0025;updCam();Object.values(NM).forEach(m=>{const bs=m.userData.baseScale||1,pl=1+Math.sin(t3*2+m.userData.phase)*.07;m.scale.setScalar(bs*pl);if(m.userData.glow)m.userData.glow.material.opacity=.09+Math.sin(t3*2+m.userData.phase)*.04;});renderer&&renderer.render(scene,camera);}
  function onMM(e){
    if(isDrag){const dx=(e.clientX-pmx)*.005,dy=(e.clientY-pmy)*.005;theta-=dx;phi=Math.max(.2,Math.min(Math.PI-.2,phi+dy));pmx=e.clientX;pmy=e.clientY;}
    const cv2=renderer.domElement,r=cv2.getBoundingClientRect();
    mouse.x=((e.clientX-r.left)/r.width)*2-1;mouse.y=-((e.clientY-r.top)/r.height)*2+1;
    rc.setFromCamera(mouse,camera);
    const ms=Object.values(NM),hits=rc.intersectObjects(ms);
    ms.forEach(m=>{if(!m.userData.selected)m.material.emissiveIntensity=.55;});
    document.getElementById('node-popup').classList.remove('show');cv2.style.cursor='default';
    if(hits.length){hits[0].object.material.emissiveIntensity=1.3;cv2.style.cursor='pointer';const nd=S.nodes.find(n=>n.id===hits[0].object.userData.nodeId);if(nd)showPopup(nd,e.clientX,e.clientY);}
  }
  function onMC(e){
    const cv2=renderer.domElement,r=cv2.getBoundingClientRect();
    mouse.x=((e.clientX-r.left)/r.width)*2-1;mouse.y=-((e.clientY-r.top)/r.height)*2+1;
    rc.setFromCamera(mouse,camera);const hits=rc.intersectObjects(Object.values(NM));
    if(hits.length){const nd=S.nodes.find(n=>n.id===hits[0].object.userData.nodeId);if(nd)toast(`${nd.label} · $${nd.avg_salary.toLocaleString()}/yr · ${(nd.satisfaction*100).toFixed(0)}% satisfaction`,'info');}
  }
  return{
    init,rebuildAll,buildEdges,clearTL,clearBL,hlTraj,animBeam,
    setRot:v=>autoRot=v,
    setLbls:v=>{showLbls=v;Object.values(NM).forEach(m=>{if(m.userData.lbl)m.userData.lbl.visible=v;});},
    resetCam:()=>{phi=Math.PI/2.5;theta=0;radius=30;},
    zoom:d=>radius=Math.max(8,Math.min(70,radius+d)),
    get autoRot(){return autoRot;},
  };
})();

