.tcard:hover{border-color:var(--cc,var(--pulsar));background:rgba(0,200,255,.04);transform:translateY(-2px)}
.tcard.best-card{border-color:var(--gold)}
.tcard.best-card::before{background:var(--gold)}
.tc-badge{position:absolute;top:9px;right:9px;font-family:'Orbitron',monospace;font-size:7px;padding:2px 6px;border:1px solid;letter-spacing:1px}
.r0{color:var(--gold);border-color:var(--gold);background:rgba(255,200,67,.08)}
.r1{color:var(--quasar);border-color:var(--quasar);background:rgba(180,77,255,.08)}
.r2{color:var(--pulsar);border-color:var(--pulsar);background:rgba(0,200,255,.08)}
.tc-path{font-family:'Share Tech Mono',monospace;font-size:9px;line-height:1.7;margin-bottom:9px;padding-right:55px;word-break:break-all}
.tc-mets{display:grid;grid-template-columns:repeat(3,1fr);gap:3px}
.tc-m{padding:3px 5px;background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.06);text-align:center}
.tc-mv{font-family:'Share Tech Mono',monospace;font-size:10px;display:block}
.tc-mk{font-size:8px;color:var(--muted);text-transform:uppercase}
.step-sec{margin-top:22px}
.step-sec-title{font-family:'Orbitron',monospace;font-size:10px;color:var(--text);letter-spacing:2px;margin-bottom:12px}
.step-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:10px}
.step-card{background:var(--panel);border:1px solid var(--border);padding:13px}
.step-num{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--muted);margin-bottom:5px}
.step-nodes{display:flex;align-items:center;gap:7px;margin-bottom:8px;flex-wrap:wrap}
.step-n{padding:3px 9px;font-size:11px;font-weight:600;border:1px solid var(--border2);background:rgba(0,200,255,.06)}
.step-n.src-n{border-color:var(--green);color:var(--green);background:rgba(0,255,140,.06)}
.step-n.dst-n{border-color:var(--gold);color:var(--gold);background:rgba(255,200,67,.06)}
.step-desc{font-size:12px;color:var(--muted);line-height:1.6}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,15,.85);z-index:500;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);opacity:0;pointer-events:none;transition:opacity .3s}
.modal-bg.show{opacity:1;pointer-events:all}
.modal{background:var(--panel2);border:1px solid var(--border2);box-shadow:var(--gb);width:390px;max-height:84vh;overflow-y:auto;padding:22px}
.modal::-webkit-scrollbar{width:3px}
.modal::-webkit-scrollbar-thumb{background:var(--border2)}
.modal h2{font-family:'Orbitron',monospace;font-size:12px;color:var(--pulsar);letter-spacing:3px;margin-bottom:18px}
.modal-acts{display:flex;gap:9px;margin-top:14px}
#toasts{position:fixed;top:68px;right:18px;z-index:600;display:flex;flex-direction:column;gap:6px}
.toast{padding:8px 13px;background:var(--panel2);border:1px solid var(--border);font-size:12px;animation:tsl .3s ease;max-width:270px;backdrop-filter:blur(12px)}
@keyframes tsl{from{transform:translateX(110%);opacity:0}to{transform:none;opacity:1}}
.t-ok{border-color:var(--green);color:var(--green)}
.t-err{border-color:var(--red);color:var(--red)}
.t-info{border-color:var(--pulsar);color:var(--pulsar)}
#loading{position:fixed;inset:0;background:var(--void);z-index:900;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;transition:opacity .8s}
#loading.out{opacity:0;pointer-events:none}
.ld-logo{font-family:'Orbitron',monospace;font-size:48px;font-weight:900;letter-spacing:10px;background:linear-gradient(90deg,var(--pulsar),var(--quasar),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:glt 2s ease-in-out infinite}
@keyframes glt{0%,100%{filter:brightness(1)}50%{filter:brightness(1.5) drop-shadow(0 0 20px rgba(0,200,255,.6))}}
.ld-sub{font-size:12px;color:var(--muted);letter-spacing:4px;text-transform:uppercase}
.ld-bar{width:160px;height:2px;background:rgba(0,200,255,.1);overflow:hidden}
.ld-fill{height:100%;background:linear-gradient(90deg,var(--quasar),var(--pulsar));animation:ldf 1.5s ease-in-out infinite}
@keyframes ldf{0%{width:0%;margin-left:0}50%{width:55%;margin-left:20%}100%{width:0%;margin-left:100%}}
*{scrollbar-width:thin;scrollbar-color:var(--border) transparent}
</style>
</head>
<body>
<canvas id="space-canvas"></canvas>
<div id="loading"><div class="ld-logo">PATHFORGE</div><div class="ld-sub">Initializing Universe Engine</div><div class="ld-bar"><div class="ld-fill"></div></div></div>
<div id="toasts"></div>
<div id="node-popup"><div id="np-title"></div><div id="np-body"></div></div>

