      <div class="stitle">Starting Point</div>
      <div class="fg"><label class="lbl">Your Current Role</label><select class="sel" id="src-sel"><option value="">— select —</option></select></div>
      <div class="fg"><label class="lbl">Your Profile</label><input class="inp" id="user-profile" value="junior developer beginning career"/></div>
    </div>
    <div class="fsec">
      <div class="stitle">Star Nodes (Career Roles)</div>
      <div class="node-list" id="node-list"></div>
      <div class="btn-row">
        <button class="btn btn-c btn-sm" style="flex:1" onclick="openModal('modal-node')">+ Add Star</button>
        <button class="btn btn-c btn-sm" style="flex:1" onclick="loadDefault()">Load Default</button>
      </div>
    </div>
    <div class="fsec">
      <div class="stitle">Wormholes (Decisions)</div>
      <div class="edge-list" id="edge-list"></div>
      <button class="btn btn-c btn-sm btn-full mt8" onclick="openModal('modal-edge')">+ Add Wormhole</button>
    </div>
    <div class="fsec">
