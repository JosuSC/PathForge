</div>

<!-- VIEW 3: ANALYSIS -->
<div class="view" id="view-analysis">
<div class="analysis-wrap">
  <div class="ah"><h2>MULTIVERSE ANALYSIS</h2><p>All discovered trajectories ranked by Pareto optimality · Click any card to highlight in Universe view</p></div>
  <div id="best-sec" style="display:none">
    <div class="best-sec">
      <div class="bt-crown">🏆</div>
