function launchExploration(){
  const src=document.getElementById('src-sel').value;
  if(!src){toast('Select a starting role first','err');return;}
  if(S.nodes.length<2){toast('Add at least 2 nodes','err');return;}
  S.exploring=true;document.getElementById('launch-btn').disabled=true;
  toast('Launching exploration...','info');switchView('universe');
  setTimeout(()=>{if(!U3D._init){U3D.init();U3D._init=true;}U3D.rebuildAll();setTimeout(startSearch,200);},100);
}

function startSearch(){
  const src=document.getElementById('src-sel').value,maxD=parseInt(document.getElementById('md').value);
  const ovl=document.getElementById('srch-overlay'),fill=document.getElementById('so-fill');
  const sub=document.getElementById('so-sub'),stat=document.getElementById('so-stat'),dots=document.getElementById('so-dots');
  ovl.classList.add('show');dots.innerHTML=Array.from({length:maxD},(_,i)=>`<div class="so-d" id="sod-${i}"></div>`).join('');
  fill.style.width='0%';S.trajectories=[];
  const req={source:src,nodes:S.nodes,edges:S.edges,profile:document.getElementById('prof-sel').value,max_years:parseInt(document.getElementById('my').value),max_risk:parseFloat(document.getElementById('mr').value),beam_width:parseInt(document.getElementById('bw').value),max_depth:maxD,top_k:parseInt(document.getElementById('tk').value),user_profile:document.getElementById('user-profile').value};
  function onStep(msg){
    fill.style.width=Math.min(98,(msg.depth/maxD)*100)+'%';sub.textContent=`Beam Search · Depth ${msg.depth} of ${maxD}`;stat.textContent=`${msg.beam.length} active beams · ${msg.completed.length} paths discovered`;
    const dd=document.getElementById(`sod-${msg.depth-1}`);if(dd)dd.classList.add('on');
    document.getElementById('sb-st').textContent='Exploring';document.getElementById('sb-d').textContent=msg.depth;document.getElementById('sb-b').textContent=msg.beam.length;document.getElementById('sb-p').textContent=msg.completed.length;
    U3D.animBeam(msg.beam,msg.completed);
  }
  function onResult(msg){S.trajectories=msg.trajectories||[];fill.style.width='100%';sub.textContent='Processing results...';updateStats();renderAnalysis();document.getElementById('tab-analysis').classList.add('has-data');}
  function onDone(){
    S.exploring=false;document.getElementById('launch-btn').disabled=false;ovl.classList.remove('show');
    document.getElementById('sb-st').textContent='Complete';document.getElementById('sb-p').textContent=S.trajectories.length;
    U3D.clearBL();toast(`${S.trajectories.length} futures discovered!`,'ok');
    const top=S.trajectories.slice(0,Math.min(3,S.trajectories.length)),cols=[0xffd700,0xb44dff,0x00c8ff];let i=0;
    const cy=setInterval(()=>{if(i>=top.length){clearInterval(cy);if(S.trajectories.length){U3D.hlTraj(S.trajectories[0].nodes,0xffd700);toast('Best trajectory highlighted in gold','ok');}return;}U3D.hlTraj(top[i].nodes,cols[i%3]);i++;},1100);
  }
  function onErr(msg){console.warn('WS err, demo fallback:',msg);runDemo(req,onStep,onResult,onDone);}
  try{API.exploreWS(req,onStep,onResult,onDone,onErr);}catch(e){runDemo(req,onStep,onResult,onDone);}
}

function renderAnalysis(){
  const trajs=S.trajectories;document.getElementById('traj-count').textContent=`(${trajs.length} total · ${trajs.filter(t=>t.pareto_rank===0).length} optimal)`;
  if(trajs.length){
    const best=trajs[0];document.getElementById('best-sec').style.display='block';
    document.getElementById('bt-path').innerHTML=best.nodes.map((n,i)=>`${i>0?'<span class="bt-arrow">→</span>':''}<span class="bt-node">${S.nodes.find(nd=>nd.id===n)?.label||n}</span>`).join('');
    const s=best.scores;
    document.getElementById('bt-mets').innerHTML=`<div class="bt-m"><div class="bt-mv">+${((s.salary_growth||0)*100).toFixed(0)}%</div><div class="bt-mk">Salary Growth</div></div><div class="bt-m"><div class="bt-mv">$${(s.final_salary||0).toLocaleString('en',{maximumFractionDigits:0})}</div><div class="bt-mk">Final Salary</div></div><div class="bt-m"><div class="bt-mv">${(s.total_years||0).toFixed(0)} yr</div><div class="bt-mk">Duration</div></div><div class="bt-m"><div class="bt-mv">${((s.avg_satisfaction||0)*100).toFixed(0)}%</div><div class="bt-mk">Satisfaction</div></div>`;
    renderSteps(best);
  }
  const grid=document.getElementById('traj-grid'),cols=[0xffd700,0xb44dff,0x00c8ff,0xff6b35,0x00ff8c,0xff3355];
  grid.innerHTML='';
  trajs.forEach((t,i)=>{
    const s=t.scores,rnk=Math.min(t.pareto_rank,2),col=pc(i);
    const card=document.createElement('div');card.className=`tcard${i===0?' best-card':''}`;card.style.setProperty('--cc',col);
    const rl=t.pareto_rank===0?'OPTIMAL':`RANK ${t.pareto_rank}`;
    const pathStr=t.nodes.map(n=>S.nodes.find(nd=>nd.id===n)?.label||n).join(' → ');
    card.innerHTML=`<div class="tc-badge r${rnk}">${rl}</div><div class="tc-path">${pathStr}</div><div class="tc-mets"><div class="tc-m"><span class="tc-mv" style="color:var(--green)">+${((s.salary_growth||0)*100).toFixed(0)}%</span><span class="tc-mk">growth</span></div><div class="tc-m"><span class="tc-mv" style="color:var(--gold)">$${Math.round((s.final_salary||0)/1000)}k</span><span class="tc-mk">final sal</span></div><div class="tc-m"><span class="tc-mv">${(s.total_years||0).toFixed(0)}yr</span><span class="tc-mk">duration</span></div><div class="tc-m"><span class="tc-mv" style="color:${(s.avg_risk||0)>.5?'var(--red)':'var(--green)'}">${((s.avg_risk||0)*100).toFixed(0)}%</span><span class="tc-mk">risk</span></div><div class="tc-m"><span class="tc-mv" style="color:var(--quasar)">${((s.avg_satisfaction||0)*100).toFixed(0)}%</span><span class="tc-mk">satisf.</span></div><div class="tc-m"><span class="tc-mv">${((s.avg_demand||0)*100).toFixed(0)}%</span><span class="tc-mk">demand</span></div></div>`;
    card.onclick=()=>{switchView('universe');setTimeout(()=>U3D.hlTraj(t.nodes,cols[i%cols.length]),100);toast(`Highlighted: ${t.nodes.slice(0,3).join(' → ')}...`,'info');};
    grid.appendChild(card);
  });
}
function renderSteps(traj){
  const sec=document.getElementById('step-sec'),grid=document.getElementById('step-grid');sec.style.display='block';grid.innerHTML='';
  for(let i=0;i<traj.nodes.length-1;i++){
    const fr=traj.nodes[i],to=traj.nodes[i+1];const frN=S.nodes.find(n=>n.id===fr),toN=S.nodes.find(n=>n.id===to);const edge=S.edges.find(e=>e.from_node===fr&&e.to_node===to);
    const card=document.createElement('div');card.className='step-card';
    card.innerHTML=`<div class="step-num">Decision ${i+1} of ${traj.nodes.length-1}</div><div class="step-nodes"><span class="step-n src-n">${frN?.label||fr}</span><span style="color:var(--muted);font-size:16px">→</span><span class="step-n dst-n">${toN?.label||to}</span></div><div class="step-desc">${edge?`~${edge.transition_years} year${edge.transition_years!==1?'s':''} · Difficulty ${(edge.difficulty*100).toFixed(0)}% · Risk ${(edge.risk*100).toFixed(0)}%.`:''} ${toN?`Salary becomes $${toN.avg_salary.toLocaleString()}/yr · ${(toN.satisfaction*100).toFixed(0)}% satisfaction.`:''}</div>`;
    grid.appendChild(card);
  }
}
async function requestAnalysis(){
  if(!S.trajectories.length){toast('Run exploration first','err');return;}
  const crit=document.getElementById('crit-disp').value||document.getElementById('criterion').value;const prof=document.getElementById('user-profile').value;
  const el=document.getElementById('llm-body'),btn=document.getElementById('analyze-btn');
  el.textContent='';el.classList.add('llm-typing');btn.disabled=true;toast('Consulting Gemini...','info');
  try{const res=await API.analyze(S.trajectories.slice(0,5),crit,prof);el.classList.remove('llm-typing');el.textContent=res.analysis||'Analysis unavailable.';toast('Gemini analysis ready','ok');}
  catch(e){el.classList.remove('llm-typing');el.textContent='[Backend offline]\n\nTo enable Gemini analysis, run:\n  python main_api.py\n\nThen click Analyze again.';toast('Backend offline — demo mode','info');}
  finally{btn.disabled=false;}
}
function toggleRot(){S.autoRot=!S.autoRot;U3D.setRot(S.autoRot);document.getElementById('cb-rot').classList.toggle('on',S.autoRot);}
function resetCam(){U3D.resetCam();}
function toggleAllTraj(){S.showAllTraj=!S.showAllTraj;document.getElementById('cb-traj').classList.toggle('on',S.showAllTraj);if(S.showAllTraj&&S.trajectories.length){const cl=[0xffd700,0xb44dff,0x00c8ff,0xff6b35,0x00ff8c];S.trajectories.slice(0,5).forEach((t,i)=>setTimeout(()=>U3D.hlTraj(t.nodes,cl[i]),i*280));}else U3D.clearTL();}
function toggleLbls(){S.showLbls=!S.showLbls;U3D.setLbls(S.showLbls);document.getElementById('cb-lbl').classList.toggle('on',S.showLbls);}
function doZoom(d){U3D.zoom(d);}
function syncCrit(src){const other=src==='criterion'?'crit-disp':'criterion';document.getElementById(other).value=document.getElementById(src).value;}

