// F. DEMO ENGINE
function runDemo(req,onStep,onResult,onDone){
  toast('Running in demo mode (backend offline)','info');
  const adj={};S.edges.forEach(e=>{if(!adj[e.from_node])adj[e.from_node]=[];adj[e.from_node].push(e.to_node);});
  let beam=[[req.source]],completed=[],depth=0;
  const maxD=Math.min(req.max_depth||5,6),bw=req.beam_width||8;
  function step(){
    if(depth>=maxD||!beam.length){
      const sc=completed.slice(0,20).map((path,i)=>{
        const n0=S.nodes.find(n=>n.id===path[0]),nF=S.nodes.find(n=>n.id===path[path.length-1]);
        const sg=nF&&n0?(nF.avg_salary-n0.avg_salary)/Math.max(n0.avg_salary,1):Math.random()*3;
        return{nodes:path,pareto_rank:i<3?0:i<7?1:2,crowding_distance:Math.random()*5,scores:{salary_growth:+sg.toFixed(3),avg_demand:+(.6+Math.random()*.35).toFixed(3),avg_satisfaction:+(.6+Math.random()*.28).toFixed(3),final_salary:nF?nF.avg_salary:50000+Math.random()*120000,total_years:path.length*2,avg_risk:+(.1+Math.random()*.5).toFixed(3),avg_difficulty:+(.2+Math.random()*.55).toFixed(3)}};
      }).sort((a,b)=>b.scores.salary_growth-a.scores.salary_growth);
      onResult({trajectories:sc});onDone();return;
    }
    const nb=[];
    beam.forEach(path=>{const cur=path[path.length-1];(adj[cur]||[]).forEach(next=>{if(!path.includes(next)){const np=[...path,next];if(np.length>=2)completed.push(np);nb.push(np);}});});
    beam=nb.slice(0,bw);depth++;
    onStep({depth,beam,completed:completed.slice(-15)});
    setTimeout(step,520);
  }
  setTimeout(step,200);
}

