      <div class="fg"><label class="lbl">Beam Width <span class="rng-v" id="bw-v">10</span></label><input class="rng" id="bw" type="range" min="2" max="20" step="1" value="10"/></div>
      <div class="fg"><label class="lbl">Max Depth <span class="rng-v" id="md-v">6</span></label><input class="rng" id="md" type="range" min="2" max="8" step="1" value="6"/></div>
      <div class="fg"><label class="lbl">Top K Results <span class="rng-v" id="tk-v">15</span></label><input class="rng" id="tk" type="range" min="5" max="30" step="1" value="15"/></div>
    </div>
    <div class="fsec">
      <div class="stitle">Constraints</div>
      <div class="fg"><label class="lbl">Profile</label>
        <select class="sel" id="prof-sel">
          <option value="balanced">Balanced</option>
