  <div class="fg"><label class="lbl">Node ID</label><input class="inp" id="nn-id" placeholder="senior_dev"/></div>
  <div class="fg"><label class="lbl">Display Label</label><input class="inp" id="nn-label" placeholder="Senior Developer"/></div>
  <div class="fg"><label class="lbl">Average Salary (USD/year)</label><input class="inp" id="nn-salary" type="number" placeholder="75000"/></div>
  <div class="fg"><label class="lbl">Market Demand <span id="nn-dem-v" style="color:var(--pulsar)">0.80</span></label><input class="rng" id="nn-dem" type="range" min="0" max="1" step="0.05" value="0.8"/></div>
  <div class="fg"><label class="lbl">Job Satisfaction <span id="nn-sat-v" style="color:var(--pulsar)">0.75</span></label><input class="rng" id="nn-sat" type="range" min="0" max="1" step="0.05" value="0.75"/></div>
  <div class="fg"><label class="lbl">Experience Required (years)</label><input class="inp" id="nn-exp" type="number" value="3"/></div>
  <div class="fg"><label class="lbl">Skills (comma separated)</label><input class="inp" id="nn-skills" placeholder="python, leadership"/></div>
  <div class="modal-acts">
    <button class="btn btn-c" onclick="closeModal('modal-node')">Cancel</button>
    <button class="btn btn-g btn-full" onclick="confirmAddNode()">Add Star</button>
  </div>
</div>
</div>

<!-- MODAL: Add Edge -->
<div class="modal-bg" id="modal-edge">
<div class="modal">
  <h2>🌀 Add Wormhole</h2>
  <div class="fg"><label class="lbl">From Node</label><select class="sel" id="ee-from"></select></div>
  <div class="fg"><label class="lbl">To Node</label><select class="sel" id="ee-to"></select></div>
  <div class="fg"><label class="lbl">Transition Years</label><input class="inp" id="ee-years" type="number" value="2" min="0"/></div>
